Query 1:
- ACE violations over time by borough
SELECT
    d.year,
    d.month,
    l.borough,
    COUNT(*) AS total_ace_violations
FROM Fact_ACE_Violations f
JOIN Dim_Date d
    ON f.date_key = d.date_key
JOIN Dim_Location l
    ON f.location_key = l.location_key
GROUP BY
    d.year,
    d.month,
    l.borough
ORDER BY
    d.year,
    d.month,
    total_ace_violations DESC;

Query 2:

- Identifies most common violations types in each borough.

SELECT
    l.borough,
    vt.violation_category,
    COUNT(*) AS total_violations
FROM Fact_ACE_Violations f
JOIN Dim_Location l
    ON f.location_key = l.location_key
JOIN Dim_ACE_Violation_Type vt
    ON f.violation_type_key = vt.violation_type_key
GROUP BY
    l.borough,
    vt.violation_category
ORDER BY
    total_violations DESC;

Query 3:

- Shows where public complaints are concentrated and what types of curb-related issues are being reported.

SELECT
    l.borough,
    ct.complaint_type,
    COUNT(*) AS total_complaints
FROM Fact_311_Complaints f
JOIN Dim_Location l
    ON f.location_key = l.location_key
JOIN Dim_311_Complaint_Type ct
    ON f.complaint_type_key = ct.complaint_type_key
GROUP BY
    l.borough,
    ct.complaint_type
ORDER BY
    total_complaints DESC;

Query 4:

- Compares ACE enforcement activity and 311 complaint activity at the same locations.

WITH ace_by_location AS (
    SELECT
        location_key,
        COUNT(*) AS total_ace_violations
    FROM Fact_ACE_Violations
    GROUP BY location_key
),

complaints_by_location AS (
    SELECT
        location_key,
        COUNT(*) AS total_311_complaints
    FROM Fact_311_Complaints
    GROUP BY location_key
)

SELECT
    l.borough,
    l.zip_code,
    COALESCE(a.total_ace_violations, 0) AS total_ace_violations,
    COALESCE(c.total_311_complaints, 0) AS total_311_complaints
FROM Dim_Location l
LEFT JOIN ace_by_location a
    ON l.location_key = a.location_key
LEFT JOIN complaints_by_location c
    ON l.location_key = c.location_key
WHERE
    COALESCE(a.total_ace_violations, 0) > 0
    OR COALESCE(c.total_311_complaints, 0) > 0
ORDER BY
    total_ace_violations DESC,
    total_311_complaints DESC;

Query 5:

Creates a  Squeeze Index using:

ACE violations
311 complaints

The final score ranges from 0 to 100.

WITH ace_metrics AS (
    SELECT
        location_key,
        COUNT(*) AS total_ace_violations
    FROM Fact_ACE_Violations
    GROUP BY location_key
),

complaint_metrics AS (
    SELECT
        location_key,
        COUNT(*) AS total_311_complaints
    FROM Fact_311_Complaints
    GROUP BY location_key
),

combined_metrics AS (
    SELECT
        l.location_key,
        l.borough,
        l.zip_code,
        COALESCE(a.total_ace_violations, 0) AS total_ace_violations,
        COALESCE(c.total_311_complaints, 0) AS total_311_complaints
    FROM Dim_Location l
    LEFT JOIN ace_metrics a
        ON l.location_key = a.location_key
    LEFT JOIN complaint_metrics c
        ON l.location_key = c.location_key
    WHERE
        COALESCE(a.total_ace_violations, 0) > 0
        OR COALESCE(c.total_311_complaints, 0) > 0
),

normalized_metrics AS (
    SELECT
        *,
        (total_ace_violations - MIN(total_ace_violations) OVER()) /
            NULLIF(MAX(total_ace_violations) OVER() - MIN(total_ace_violations) OVER(), 0)
            AS normalized_ace_violations,

        (total_311_complaints - MIN(total_311_complaints) OVER()) /
            NULLIF(MAX(total_311_complaints) OVER() - MIN(total_311_complaints) OVER(), 0)
            AS normalized_311_complaints
    FROM combined_metrics
)

SELECT
    borough,
    zip_code,
    total_ace_violations,
    total_311_complaints,

    ROUND(
        (
            normalized_ace_violations * 0.6
            +
            normalized_311_complaints * 0.4
        ) * 100,
        2
    ) AS squeeze_index_score

FROM normalized_metrics
ORDER BY squeeze_index_score DESC
LIMIT 25;
